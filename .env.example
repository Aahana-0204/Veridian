# ─────────────────────────────────────────────
#  Veridian — Environment Variables
#  Copy this file to .env and fill in values.
#  Never commit .env to source control.
# ─────────────────────────────────────────────

# ── Application ──────────────────────────────
# "development" | "staging" | "production"
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# Secret used for JWT signing — generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-a-long-random-string

# ── Database ─────────────────────────────────
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword
POSTGRES_DB=ragdb

# Used by the backend service (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb

# Used by Alembic CLI (sync driver, no +asyncpg)
ALEMBIC_DATABASE_URL=postgresql://raguser:ragpassword@localhost:5432/ragdb

# ── Redis ─────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── CORS ─────────────────────────────────────
# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173

# ── Frontend (Vite env vars must start with VITE_) ──
VITE_API_URL=http://localhost:8000

# ── Auth ─────────────────────────────────────────────────────────────────────
# Short-lived access token — 15 min is the recommended production default
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Upload / Storage ──────────────────────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=/tmp/veridian_uploads

# ── Chunking ──────────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── Embeddings ────────────────────────────────────────────────────────────────
# FREE DEFAULT: sentence-transformers runs locally, no API key needed.
# Switch to "openai" + set OPENAI_API_KEY if you want OpenAI embeddings.
EMBEDDING_PROVIDER=sentence-transformers

# OpenAI settings — only needed if EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Must match the pgvector column size AND the chosen model's output dimension.
# sentence-transformers/all-MiniLM-L6-v2 → 384  ← FREE default (run migration c3d4e5f6a1b2)
# openai/text-embedding-3-small           → 1536 (paid, original Part 2 default)
EMBEDDING_DIMENSIONS=384

# SentenceTransformers model (used when EMBEDDING_PROVIDER=sentence-transformers)
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2

# Rate / cost safety
EMBEDDING_BATCH_SIZE=100       # max texts per single API call
EMBEDDING_MAX_CONCURRENCY=3    # max concurrent API calls

# Retry / back-off
EMBEDDING_MAX_RETRIES=3
EMBEDDING_RETRY_BASE_DELAY=1.0   # seconds
EMBEDDING_RETRY_MAX_DELAY=60.0   # seconds

# ── Test Database ─────────────────────────────────────────────────────────────
# Separate DB for running pytest — never the same as DATABASE_URL above
TEST_DATABASE_URL=postgresql+asyncpg://raguser:ragpassword@localhost:5432/ragdb_test

# -- Retrieval ----------------------------------------------------------------
TOP_K=5
HYBRID_SEARCH_ENABLED=true
RETRIEVAL_CANDIDATE_MULTIPLIER=4

# -- Re-ranking (disabled by default - adds latency) -------------------------
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_N_MULTIPLIER=4

# -- LLM / Generation --------------------------------------------------------
# FREE DEFAULT: Groq — free tier at https://console.groq.com
# Sign up → Create API key → paste below. No credit card required.
# Free limits: 30 req/min, 6,000 req/day.
LLM_PROVIDER=groq
LLM_MODEL=llama-3.1-8b-instant
GROQ_API_KEY=gsk_...

# Switch to OpenAI (paid) if you prefer:
# LLM_PROVIDER=openai
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048
LLM_CONTEXT_WINDOW=128000

# -- Prompt ------------------------------------------------------------------
PROMPT_TEMPLATE=rag_v1
MAX_CONTEXT_TOKENS=4000
MAX_HISTORY_TOKENS=1000
